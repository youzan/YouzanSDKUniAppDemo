{
    "name": "YouzanUniPlugin",
    "id": "YouzanUniPlugin",
    "version": "1.0.0",
    "description": "有赞SDK插件",
    "_dp_type": "nativeplugin",
    "_dp_nativeplugin": {
        "ios": {
            "plugins": [{
                "type": "module",
                "name": "YouzanUniPlugin-YZUniModule",
                "class": "YZUniModule"
